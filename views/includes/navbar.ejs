<style>
 .btn-search{
   background-color: #fe424d;
   color: white;
   border-radius: 25px;

   display: inline-flex;
   align-items: center;
   gap: 6px;
   white-space: nowrap;
}

.btn-search:hover{
   background-color: #ee3b46;
   color: white;
}

.input-search{
  border-radius: 25px;
  padding: 0.5rem 3rem 0.5rem 3rem;
  font-size: 1rem;
}
</style>

<nav class="navbar navbar-expand-md sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <div class="search ms-auto px-2">
        <form class="d-flex" role="search">
      <input class="form-control me-2 input-search" type="search" placeholder="Search Destinations" aria-label="Search"/>
      <button class="btn btn-search" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
    </form>
      </div>

      <div class="navbar-nav ms-auto">
        <% if(!currentUser){ %> 
          <a class="nav-link" href="/signup">Sign Up</a>
          <a class="nav-link" href="/login">Log In</a>
          <%}%>
          <% if(currentUser){ %> 
        <a class="nav-link" href="/listings/new">Add New Listing</a>
        <a class="nav-link" href="/logout">Log Out</a>
        <%}%>
      </div>
    </div>
  </div>
</nav>
