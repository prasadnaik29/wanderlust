<% layout('/layouts/boilerplate') -%>

<div class="container py-5">
  <div class="card shadow-lg border-0 rounded-4 overflow-hidden mb-5">
    <div class="row g-0">
      <!-- Image Section -->
      <div class="col-md-6">
        <img
          src="<%= listing.image.url %>"
          class="img-fluid h-100 w-100 object-fit-cover"
          style="max-height: 500px"
          alt="<%= listing.title %>"
        />
      </div>

      <!-- Details Section -->
      <div
        class="col-md-6 p-4 p-md-5 d-flex flex-column justify-content-between"
      >
        <div>
          <h2 class="fw-bold mb-3"><%= listing.title %></h2>

          <i class="card-text fw-bold mb-3">Owned by: <%= listing.owner.username %></i>

          <h4 class="text-primary fw-semibold mb-3">
            ₹ <%= listing.price.toLocaleString("en-IN") %>
            <span class="fs-6 text-muted">/ Night</span>
          </h4>

          <p class="text-muted mb-4"><%= listing.description %></p>

          <p class="mb-1">
            <i class="fa-solid fa-location-dot me-2 text-danger"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>
        </div>

        <!-- Buttons -->
         <% if(currentUser && listing.owner._id.equals(currentUser._id)){ %>
        <div class="mt-4 d-flex gap-3">
          <a
            href="/listings/<%= listing._id %>/edit"
            class="btn btn-outline-primary px-4"
          >
            Edit
          </a>

          <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=DELETE"
          >
            <button class="btn btn-outline-danger px-4">Delete</button>
          </form>
        </div>
        <% }; %>
      </div>
    </div>
  </div>

  <hr />

  <% if(currentUser) {%>
  <form
    method="POST"
    action="/listings/<%= listing._id %>/reviews"
    class="container my-5 needs-validation"
    style="max-width: 500px"
    novalidate
  >
   <div class="mb-3">
  <h2>Leave a Review</h2>
  <label class="form-label">Rating</label>

  <fieldset class="starability-basic">
    <input type="radio" id="rate1" name="review[rating]" value="1" required />
    <label for="rate1">1 star</label>

    <input type="radio" id="rate2" name="review[rating]" value="2" />
    <label for="rate2">2 stars</label>

    <input type="radio" id="rate3" name="review[rating]" value="3" />
    <label for="rate3">3 stars</label>

    <input type="radio" id="rate4" name="review[rating]" value="4" />
    <label for="rate4">4 stars</label>

    <input type="radio" id="rate5" name="review[rating]" value="5" />
    <label for="rate5">5 stars</label>
  </fieldset>

  <div class="invalid-feedback">
    Please select a rating
  </div>
</div>
  

      <div class="">
        <label for="comment" class="form-label">Comment</label>
        <textarea
          class="form-control"
          name="review[comment]"
          id="comment"
          comment
          cols="60"
          rows="6"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter a valid comment</div>
      </div>
      <button class="btn btn-danger my-3">Submit</button>
    </div>
  </form>
  <hr>
  <% } %>
  <div class="row d-flex justify-content-center">
 <% listing.reviews.forEach(review => { %>
      <div class="col-md-4 mx-2 my-2">
        <div class="card p-4">
           <h4>@<%= review.author.username %></h4>
           <p class="starability-result" data-rating=<%= review.rating %>></p>
           <p><%= review.comment %></p>
           <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
             <button class="btn btn-outline-danger ">Delete</button>
           </form>
          </div>
        </div>
    <%}); %>
    </div>
</div>
